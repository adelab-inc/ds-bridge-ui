{
  "componentName": "DataGrid",
  "category": "data-display",
  "props": {
    "rowData": { "type": "any[]", "required": true },
    "columnDefs": { "type": "(ColDef | ColGroupDef)[]", "required": true },
    "theme": { "type": "GridThemePreset | AgGridTheme", "required": false, "defaultValue": "aplus" },
    "themeParams": { "type": "ThemeParams", "required": false },
    "height": { "type": "number | string", "required": false, "defaultValue": 400 },
    "width": { "type": "number | string", "required": false, "defaultValue": "100%" },
    "className": { "type": "string", "required": false },
    "pagination": { "type": "boolean", "required": false, "defaultValue": false },
    "paginationPageSize": { "type": "number", "required": false, "defaultValue": 10 },
    "paginationPageSizeSelector": { "type": "number[]", "required": false, "defaultValue": [10, 20, 50, 100] },
    "domLayout": { "type": "'normal' | 'autoHeight' | 'print'", "required": false, "defaultValue": "normal" },
    "rowSelection": { "type": "'single' | 'multiple'", "required": false },
    "enableFilter": { "type": "boolean", "required": false, "defaultValue": true },
    "enableSorting": { "type": "boolean", "required": false, "defaultValue": true },
    "quickFilterText": { "type": "string", "required": false },
    "loading": { "type": "boolean", "required": false, "defaultValue": false },
    "loadingOverlayComponent": { "type": "string", "required": false },
    "noRowsOverlayComponent": { "type": "string", "required": false },
    "animateRows": { "type": "boolean", "required": false, "defaultValue": true },
    "autoGroupColumnDef": { "type": "ColDef", "required": false },
    "editType": { "type": "'fullRow'", "required": false },
    "stopEditingWhenCellsLoseFocus": { "type": "boolean", "required": false, "defaultValue": true },
    "cellSelection": { "type": "boolean", "required": false, "defaultValue": false },
    "enableCharts": { "type": "boolean", "required": false, "defaultValue": false },
    "onGridReady": { "type": "(event: GridReadyEvent) => void", "required": false },
    "onSelectionChanged": { "type": "(event: SelectionChangedEvent) => void", "required": false },
    "onCellClicked": { "type": "(event: CellClickedEvent) => void", "required": false },
    "onRowSelected": { "type": "(event: RowSelectedEvent) => void", "required": false },
    "onFilterChanged": { "type": "(event: FilterChangedEvent) => void", "required": false },
    "onSortChanged": { "type": "(event: SortChangedEvent) => void", "required": false },
    "onCellValueChanged": { "type": "(event: CellValueChangedEvent) => void", "required": false },
    "onColumnMoved": { "type": "(event: ColumnMovedEvent) => void", "required": false },
    "onRowDataChanged": { "type": "() => void", "required": false },
    "getRowId": { "type": "(params: GetRowIdParams) => string", "required": false },
    "getRowClass": { "type": "(params: RowClassParams) => string | string[]", "required": false },
    "defaultColDef": { "type": "ColDef", "required": false },
    "sideBar": { "type": "boolean | string | any", "required": false, "defaultValue": false },
    "maintainColumnOrder": { "type": "boolean", "required": false, "defaultValue": true },
    "rowModelType": { "type": "'clientSide' | 'infinite' | 'viewport' | 'serverSide'", "required": false, "defaultValue": "clientSide" },
    "enableAdvancedFilter": { "type": "boolean", "required": false },
    "showColumnMenu": { "type": "boolean", "required": false, "defaultValue": false },
    "cellVerticalAlign": { "type": "CellVerticalAlign", "required": false, "defaultValue": "center" },
    "showRowLine": { "type": "boolean", "required": false, "defaultValue": false },
    "emptyValueDisplay": { "type": "string | false", "required": false, "defaultValue": "-" },
    "showColumnBorder": { "type": "boolean", "required": false, "defaultValue": false },
    "showHeaderColumnBorder": { "type": "boolean", "required": false, "defaultValue": true },
    "rowHeight": { "type": "number", "required": false, "defaultValue": 40 },
    "headerHeight": { "type": "number", "required": false, "defaultValue": 42 },
    "noRowsMessage": { "type": "string", "required": false, "defaultValue": "표시할 데이터가 없습니다" },
    "suppressRowClickSelection": { "type": "boolean", "required": false },
    "groupDisplayType": { "type": "'singleColumn' | 'multipleColumns' | 'groupRows' | 'custom'", "required": false },
    "groupDefaultExpanded": { "type": "number", "required": false },
    "readOnlyEdit": { "type": "boolean", "required": false },
    "enableRangeSelection": { "type": "boolean", "required": false },
    "treeData": { "type": "boolean", "required": false },
    "enableCellTextSelection": { "type": "boolean", "required": false },
    "getDataPath": { "type": "(data: any) => string[]", "required": false },
    "suppressAggFuncInHeader": { "type": "boolean", "required": false },
    "pinnedTopRowData": { "type": "any[]", "required": false },
    "pinnedBottomRowData": { "type": "any[]", "required": false },
    "context": { "type": "any", "required": false },
    "onRowDoubleClicked": { "type": "(event: any) => void", "required": false },
    "getRowStyle": { "type": "(params: any) => any", "required": false },
    "rowGroupPanelShow": { "type": "'always' | 'never' | 'onlyWhenGrouping'", "required": false },
    "aggFuncs": { "type": "Record<string, (params: any) => any>", "required": false },
    "suppressMovableColumns": { "type": "boolean", "required": false }
  }
}

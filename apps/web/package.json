{
  "name": "@ds-hub/web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.0.0"
  },
  "scripts": {
    "predev": "cp ../../storybook-standalone/packages/ui/dist/ui.umd.js public/ui-bundle.js 2>/dev/null; cp ../../storybook-standalone/packages/ui/dist/ui.css public/ui-bundle.css 2>/dev/null; true",
    "dev": "next dev --port 5555",
    "prebuild": "cd ../../storybook-standalone/packages/ui && pnpm install && pnpm build:umd",
    "build": "next build",
    "postbuild": "cp ../../storybook-standalone/packages/ui/dist/ui.umd.js public/ui-bundle.js && cp ../../storybook-standalone/packages/ui/dist/ui.css public/ui-bundle.css",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.6",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.99.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lottie-react": "^2.4.1",
    "next": "16.2.4",
    "playwright": "^1.59.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^3.8.5",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  }
}
